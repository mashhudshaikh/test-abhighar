# Phase 2 — Lead Intake (site → API)
#
# Shared HMAC secret. MUST exactly match the value in abhighar-api/.env
# Generate a fresh one with:  openssl rand -base64 48
# Minimum 32 characters. Treat like a password — don't commit, don't log.
LEAD_INTAKE_SECRET=

# URL where the NestJS API is running. In dev: http://localhost:3000
# In prod: https://api.abhighar.com (or wherever you host the API)
ABHIGHAR_API_URL=http://localhost:3000
